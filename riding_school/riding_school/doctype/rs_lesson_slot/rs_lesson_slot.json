{
  "name": "RS Lesson Slot",
  "doctype": "DocType",
  "module": "Riding School",
  "fields": [
    {
      "fieldname": "slot_date",
      "fieldtype": "Date",
      "label": "Datum",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "start_time",
      "fieldtype": "Time",
      "label": "Beginn",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "end_time",
      "fieldtype": "Time",
      "label": "Ende",
      "reqd": 1
    },
    {
      "fieldname": "instructor",
      "fieldtype": "Link",
      "label": "Reitlehrer",
      "options": "RS Instructor",
      "in_list_view": 1
    },
    {
      "fieldname": "facility",
      "fieldtype": "Link",
      "label": "Reitplatz",
      "options": "RS Facility"
    },
    {
      "fieldname": "sb_details",
      "fieldtype": "Section Break",
      "label": "Details"
    },
    {
      "fieldname": "slot_type",
      "fieldtype": "Select",
      "label": "Typ",
      "options": "Einzelstunde\nGruppenstunde\nEvent",
      "default": "Einzelstunde"
    },
    {
      "fieldname": "skill_level",
      "fieldtype": "Select",
      "label": "Skill Level",
      "options": "Beginner\nIntermediate\nAdvanced\nCompetition"
    },
    {
      "fieldname": "max_participants",
      "fieldtype": "Int",
      "label": "Teilnehmer",
      "default": "1"
    },
    {
      "fieldname": "cb_details",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nPlanned\nReleased\nBooked\nCompleted\nCancelled",
      "default": "Open",
      "read_only": 1
    },
    {
      "fieldname": "sb_participants",
      "fieldtype": "Section Break",
      "label": "Teilnehmer"
    },
    {
      "fieldname": "participants",
      "fieldtype": "Table",
      "label": "Teilnehmer",
      "options": "RS Slot Participant"
    },
    {
      "fieldname": "sb_logbook",
      "fieldtype": "Section Break",
      "label": "Logbuch"
    },
    {
      "fieldname": "logbook_entry",
      "fieldtype": "Text Editor",
      "label": "Kommentar Reitlehrer"
    }
  ],
  "calendar_view": [
    {
      "field_to_use_as_start": "slot_date",
      "field_to_use_as_end": "slot_date",
      "all_day": 0
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Riding School Backoffice",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Riding School Instructor",
      "read": 1,
      "write": 1
    },
    {
      "role": "Riding School Rider",
      "read": 1
    }
  ],
  "track_changes": 1,
  "default_view": "Calendar"
}